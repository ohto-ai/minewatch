# MC Server Log Fetcher — environment variables
# Copy this file to .env and fill in your real credentials:
#   cp .env.example .env

MC_BASE_URL=http://xcon.top:8585
MC_USERNAME=your_username_here
MC_PASSWORD=your_password_here
# 查询任务逐个执行间隔（秒），默认 1；仅 max_concurrency=1 时生效
MC_QUERY_TASK_STEP_INTERVAL=1
# 查询任务最大并发数，默认 3；设为 1 时退化为串行执行
MC_QUERY_TASK_CONCURRENCY=3

# Flask web viewer
# Secret key for signing session cookies.  Set this to a long random string
# in production; if omitted a random key is generated on each startup.
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# First admin account is created via the web setup wizard at /setup
# when the application runs for the first time with an empty database.

# Optional shared token for inter-server sync export authentication.
# Set the same value on both source and target Minewatch servers.
SYNC_SHARED_TOKEN=
